# Copy from .env.local on the Vercel dashboard
# https://nextjs.org/learn/dashboard-app/setting-up-your-database#create-a-postgres-database

# Parameters for Vercel Postgres Templates
POSTGRES_URL="postgres://user:password@hostname/database?sslmode=require"
POSTGRES_PRISMA_URL="postgres://user:password@hostname/database?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NO_SSL="postgres://user:password@hostname/database"
POSTGRES_URL_NON_POOLING="postgres://user:password@hostname/database?sslmode=require"
POSTGRES_USER="user"
POSTGRES_HOST="hostname"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="database"

# `openssl rand -base64 32`
AUTH_SECRET="generate_a_new_secret_using_openssl"
AUTH_URL="http://localhost:3000"
